# PostgreSQL connection string.
# Local/dev example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
# Cloudflare Workers runtime is best used with Prisma Accelerate: prisma://accelerate.prisma-data.net/?api_key=...
DATABASE_URL=

# Auth secrets, minimum 32 characters.
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=

# Seed admin credentials.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Optional. Defaults to Asia/Jakarta.
APP_TIMEZONE=Asia/Jakarta
